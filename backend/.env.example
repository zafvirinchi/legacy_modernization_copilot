# Spring profile to activate: dev | docker | prod
SPRING_PROFILES_ACTIVE=dev

# MongoDB (Atlas SRV connection, used by dev/prod profiles)
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_CLUSTER=
MONGODB_DATABASE=ai_legacy_modernization

# JWT
JWT_SECRET=change-me-to-a-256-bit-secret
APP_ADMIN_PASSWORD=admin123

# LLM providers (optional - leave blank to disable AI features)
OPENAI_API_KEY=
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_LLM_MODEL=gpt-4
AZURE_LLM_DEPLOYMENT_ID=

# Storage
TEMP_UPLOAD_DIR=./temp-uploads
OUTPUT_DIR=./output-reports
